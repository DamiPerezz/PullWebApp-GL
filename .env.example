# Pull Web App - Environment Variables Example
# Copy this file to .env and fill in your values
# SECURITY: Never commit .env files with real credentials

# API Configuration
VITE_API_URL=http://localhost:8080/api/v1

# Stripe (Public Key Only - safe to expose in frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY

# Mapbox (Public Token - safe to expose in frontend, but restrict by domain in Mapbox dashboard)
VITE_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN
